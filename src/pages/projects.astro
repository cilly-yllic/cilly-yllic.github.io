---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Mermaid from '../components/Mermaid.astro';
import DecisionList from '../components/DecisionList.astro';

const overviewDiagram = `flowchart LR
    Client[Web Client] -->|read| FS[(Firestore<br/>Public Cache)]
    Client -->|mutate| DC[Data Connect]
    DC --> SQL[(Cloud SQL<br/>Source of Truth)]
    SQL --> RT[Reconciliation Table]
    RT --> CT[Cloud Tasks<br/>Debounced]
    CT --> W[Recon Worker]
    W -->|write| FS
    W -->|index| OS[(OpenSearch)]
    AI[AI Worker] -->|GraphQL| DC`;

const reconciliationDiagram = `sequenceDiagram
    participant C as Client
    participant DC as Data Connect
    participant SQL as Cloud SQL
    participant CT as Cloud Tasks
    participant FS as Firestore

    C->>DC: mutate task
    DC->>SQL: UPDATE + INSERT recon row
    SQL-->>DC: OK
    DC-->>C: ack
    SQL->>CT: enqueue (debounced)
    Note over CT: dedupe by entity id
    CT->>FS: write denormalized doc
    FS-->>C: realtime push`;

const multiTenantDiagram = `flowchart TB
    subgraph WA[Workspace A]
        FA[Firestore /ws_A/*]
        SA[Cloud SQL workspace_id=A]
    end
    subgraph WB[Workspace B]
        FB[Firestore /ws_B/*]
        SB[Cloud SQL workspace_id=B]
    end
    Client[Authenticated Client] -->|workspace claim| FA
    Client -.->|denied| FB
    DC[Data Connect] -->|RLS workspace_id| SA
    DC -.->|RLS workspace_id| SB`;

const decisions = [
  {
    title: 'Polling を避けた',
    body: 'Polling は構造的に「変更がなくても読み続ける」浪費とレイテンシのトレードオフが生まれる。Firestore の onSnapshot による push 配信に寄せ、Cloud SQL 側の変更は Reconciliation Worker 経由で Firestore に流すことで、クライアントは常に push を待つ単純なモデルにした。',
  },
  {
    title: 'Reconciliation Table を採用',
    body: 'Data Connect から Firestore へ直接 dual write すると、片方が失敗したときに整合性を保証できない。Cloud SQL の同一トランザクション内に「reconcile すべき変更」を専用テーブルへ書き出し、後段の Worker がそのテーブルを Firestore に投影する outbox 的な設計に倒した。',
  },
  {
    title: 'Firestore を Public Cache として扱う',
    body: 'Firestore を「権威の SoT」ではなく「読み取り最適化された投影 (denormalized projection)」として扱う。書き込みは必ず Cloud SQL を経由し、Firestore は再生成可能なキャッシュとして位置づけることで、データモデルの自由度と整合性検査のしやすさを両立した。',
  },
  {
    title: 'Debounce 設計',
    body: 'AI による一括タスク生成や、Tree の親子同時編集が発生すると、reconcile キューに同一エンティティへの更新が短時間で集中する。Cloud Tasks の dedupe key にエンティティ id を採用し、200ms 程度の遅延で確定後の状態だけを Firestore へ反映する。',
  },
  {
    title: 'Consistency Check 戦略',
    body: 'Reconciliation はベストエフォートなので、定期的に Cloud SQL と Firestore のスナップショットを突き合わせる検証ジョブを走らせる。差分があれば再 reconcile を enqueue し、検出から自己修復まで自動化する。',
  },
];
---

<BaseLayout
  title="Projects · cilly-yllic"
  description="Projects showcase. Main: Task Tree — an AI-augmented hierarchical task system built on Data Connect + Firestore + Cloud Tasks reconciliation."
>
  <header class="page-header">
    <p class="eyebrow">Projects</p>
    <h1>Task Tree</h1>
    <p class="lead">
      An AI-augmented hierarchical task system. Designed around explicit
      reconciliation between a relational source-of-truth and a realtime read
      cache.
    </p>
  </header>

  <Section title="Overview">
    <p>
      Task Tree は、タスクを単なるフラットなリストではなく、分解 (decomposition)
      を一級操作とするツリー構造で扱うタスク管理サービス。AI がタスクの分解・
      要約・優先順位付けを補助し、人間の認知負荷を「どこから手を付けるか」だけに
      集中させることを狙う。
    </p>
    <p>
      対象は、ソロエンジニアや少人数の知的生産チーム。既存のタスクツールが
      「平坦なリスト」か「硬直したプロジェクト階層」のどちらかに寄っているのに
      対し、Task Tree は「思考の構造をそのまま保存できるツール」を目指す。
    </p>
  </Section>

  <Section title="Architecture">
    <p>
      バックエンドは Cloud SQL を権威データとして Data Connect (GraphQL) で
      公開し、Firestore を読み取り最適化された Public Cache として併用する
      ハイブリッド構成。Cloud Tasks による Event-driven Reconciliation で
      両者の整合を取る。
    </p>

    <Mermaid code={overviewDiagram} caption="システム全体構成 — SoT は Cloud SQL、Firestore は投影された読み取り面" />

    <h3>Reconciliation Flow</h3>
    <p>
      クライアントの mutation は Data Connect 経由で Cloud SQL に書かれ、
      同じトランザクションで Reconciliation Table にも変更が記録される。
      後段の Worker が Cloud Tasks 経由で debounce しながら Firestore を更新する。
    </p>

    <Mermaid code={reconciliationDiagram} caption="書き込みパス — SQL に commit → Cloud Tasks → Firestore 投影" />

    <h3>Multi-tenant Architecture</h3>
    <p>
      Workspace 単位のテナント分離は、Firestore はコレクションパス、Cloud SQL は
      Row-Level Security (workspace_id) で実現する。クライアントは Auth トークン
      に含まれる workspace claim を介してのみ読み書きができる。
    </p>

    <Mermaid code={multiTenantDiagram} caption="Multi-tenant — Firestore はパス分離、SQL は RLS 分離" />
  </Section>

  <Section title="Technical Decisions">
    <p>
      設計の判断軸はほぼ「変更を push する経路を一本化する」ことに集約される。
      具体的な判断は以下。
    </p>
    <DecisionList items={decisions} />
  </Section>

  <Section title="Challenges">
    <ul class="bullet-list">
      <li>
        <strong>同期整合性</strong> — Cloud SQL と Firestore の投影差を
        いかに短く保つか。Reconciliation の遅延と CPU コストのトレードオフ。
      </li>
      <li>
        <strong>分散更新</strong> — 同一 Tree への並行更新が増えると、
        親子のリンク不整合 (孤児ノード・サイクル) を生む。SQL 側の制約と
        UI の楽観ロックで両側から防ぐ。
      </li>
      <li>
        <strong>OpenSearch パフォーマンス</strong> — Parent-Child や
        Nested Query は global ordinals の再構築コストが大きく、書き込みが
        多いインデックスでは劣化する。フラット化したスナップショットを
        別インデックスに持つ戦略へ移行中。
      </li>
      <li>
        <strong>Event Ordering</strong> — Cloud Tasks は順序保証がない。
        Reconciliation Worker 側で entity id ごとの version 比較を行い、
        古い投影で新しい状態を上書きしないようにする。
      </li>
      <li>
        <strong>Client Cache Consistency</strong> — Firestore の onSnapshot は
        ローカルキャッシュを混ぜて配信するため、楽観更新と reconcile 結果が
        交錯する。クライアント側で更新元 (local / remote) を区別して
        マージするレイヤを置く。
      </li>
    </ul>
  </Section>

  <Section title="Future Vision">
    <ul class="bullet-list">
      <li>
        <strong>AI Task Generation</strong> — ゴールから Tree を生成する
        パイプライン。生成 → 人手レビュー → reconcile の 3 段で AI 出力を
        信頼可能なタスクに昇格させる。
      </li>
      <li>
        <strong>Multi Model Provider</strong> — モデル選択を Workspace 単位の
        ポリシーにする。コスト / 品質 / レイテンシのトレードオフを
        ユーザー側で制御可能にする。
      </li>
      <li>
        <strong>Workspace Isolation (強化)</strong> — Free / Pro tier で
        共有インスタンスから、Enterprise tier では専有 Firestore /
        Cloud SQL インスタンスへ分離可能にする。
      </li>
      <li>
        <strong>Realtime Collaboration</strong> — Tree への同時編集を
        CRDT ベースで扱い、Firestore は投影面、CRDT 状態は別ストアに分離する。
      </li>
    </ul>
  </Section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-16);
  }

  .eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-subtle);
    margin: 0 0 var(--space-2);
  }

  .page-header h1 {
    font-size: 2rem;
    margin: 0 0 var(--space-4);
  }

  .lead {
    font-size: 1.0625rem;
    color: var(--fg);
    max-width: 36rem;
    margin: 0;
  }

  h3 {
    font-size: 1rem;
    margin: var(--space-8) 0 var(--space-3);
    color: var(--fg);
    font-weight: 600;
  }

  .bullet-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bullet-list li {
    padding-left: var(--space-4);
    border-left: 2px solid var(--border);
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .bullet-list strong {
    color: var(--fg);
    font-weight: 600;
  }
</style>
