---
interface Decision {
  title: string;
  body: string;
}

interface Props {
  items: Decision[];
}

const { items } = Astro.props;
---

<dl class="decisions">
  {
    items.map((item) => (
      <div class="item">
        <dt>{item.title}</dt>
        <dd>{item.body}</dd>
      </div>
    ))
  }
</dl>

<style>
  .decisions {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .item {
    border-left: 2px solid var(--border);
    padding-left: var(--space-4);
  }

  dt {
    color: var(--fg);
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: var(--space-2);
  }

  dd {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }
</style>
