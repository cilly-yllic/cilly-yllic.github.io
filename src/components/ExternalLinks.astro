---
interface Link {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  title?: string;
  links: Link[];
}

const { title = 'Links', links } = Astro.props;
---

<section class="external-links">
  <h2>{title}</h2>
  <ul>
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .external-links {
    margin-bottom: var(--space-12);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  a {
    font-size: 0.9375rem;
  }
</style>
