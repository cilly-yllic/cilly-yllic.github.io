---
interface Props {
  name: string;
  tagline: string;
}

const { name, tagline } = Astro.props;
---

<header class="hero">
  <h1>{name}</h1>
  <p class="tagline">{tagline}</p>
</header>

<style>
  .hero {
    margin-bottom: var(--space-16);
  }

  .tagline {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--fg);
    margin: 0;
    max-width: 36rem;
  }
</style>
