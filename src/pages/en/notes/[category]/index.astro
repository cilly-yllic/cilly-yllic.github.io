---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { CATEGORIES, type CategorySlug } from '../../../../content.config';
import { termForNote } from '../../../../config/giscus';
import { getDiscussionStats } from '../../../../lib/discussions';

export const getStaticPaths = (async () => {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { categorySlug: cat.slug, categoryTitle: cat.titleEn },
  }));
}) satisfies GetStaticPaths;

interface Props {
  categorySlug: CategorySlug;
  categoryTitle: string;
}

const { categorySlug, categoryTitle } = Astro.props;

const notes = await getCollection(
  'notesEn',
  ({ data }) => !data.draft && data.category === categorySlug,
);
const sorted = notes.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const stats = await getDiscussionStats();

// 本文 markdown から最初の画像（![alt](src)）を取り出す
function firstImage(body?: string) {
  const m = body?.match(/!\[([^\]]*)\]\(([^)\s]+)/);
  return m ? { src: m[2], alt: m[1] } : null;
}
---

<BaseLayout
  title={`${categoryTitle} · Architecture Notes`}
  description={`Articles in the ${categoryTitle} category.`}
>
  <header class="page-header">
    <p class="eyebrow">Architecture Notes</p>
    <h1>{categoryTitle}</h1>
  </header>

  <div class="card-list">
    {
      sorted.length === 0 ? (
        <p class="empty">No articles in this category yet.</p>
      ) : (
        sorted.map((note) => {
          const img = firstImage(note.body);
          const stat = stats.get(termForNote(`en/${note.id}`));
          return (
            <ArticleCard
              title={note.data.title}
              description={note.data.description}
              category={note.data.category}
              publishedAt={note.data.publishedAt}
              href={`/en/notes/${note.id}/`}
              image={img?.src}
              imageAlt={img?.alt}
              showCategory={false}
              locale="en"
              commentCount={stat?.comments}
              reactionCount={stat?.reactions}
            />
          );
        })
      )
    }
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-12);
  }

  .eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-subtle);
    margin: 0 0 var(--space-2);
  }

  .page-header h1 {
    font-size: 1.75rem;
    margin: 0;
  }

  .card-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
  }

  .empty {
    color: var(--fg-subtle);
    font-size: 0.9375rem;
  }
</style>
