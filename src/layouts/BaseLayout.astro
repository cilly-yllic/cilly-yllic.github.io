---
import '../styles/tokens.css';
import '../styles/base.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import AnalyticsEvents from '../components/AnalyticsEvents.astro';
import { getLocaleFromPath, altPath } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  /**
   * 反対言語での同一ページのパス。
   * - 未指定: 全サイト共通ページとして altPath() で自動導出する (対応ページが常に存在する前提)
   * - null: 対応ページが存在しない (未翻訳記事など)。プルダウンはセクションのトップへフォールバックし、
   *   hreflang と自動リダイレクトは無効になる
   */
  altUrl?: string | null;
}

const locale = getLocaleFromPath(Astro.url.pathname);

const {
  title = 'cilly',
  description = 'Full-cycle web engineer focused on scalable architecture, AI-integrated systems, and product-oriented development.',
  ogType = 'website',
  altUrl = altPath(Astro.url.pathname),
} = Astro.props;

const ogImage = new URL('/og-image.png', Astro.site).toString();
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const altLocale = locale === 'ja' ? 'en' : 'ja';
const altAbsolute = altUrl ? new URL(altUrl, Astro.site).toString() : null;

const rssHref = locale === 'en' ? '/en/notes/rss.xml' : '/notes/rss.xml';
const rssTitle = locale === 'en' ? 'cilly — Architecture Notes (EN)' : 'cilly — Architecture Notes';
---

<!doctype html>
<html lang={locale} data-locale={locale} data-alt-url={altUrl ?? undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <GoogleAnalytics />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {altAbsolute && <link rel="alternate" hreflang={altLocale} href={altAbsolute} />}
    {altAbsolute && <link rel="alternate" hreflang={locale} href={canonical} />}
    {
      altAbsolute && (
        <link rel="alternate" hreflang="x-default" href={locale === 'ja' ? canonical : altAbsolute} />
      )
    }

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline>
      // Set theme before render to avoid FOUC.
      (() => {
        const v = localStorage.getItem('theme');
        if (v === 'light' || v === 'dark') {
          document.documentElement.dataset.theme = v;
        }
      })();
    </script>

    <script is:inline>
      // 言語設定の引き継ぎ: ヘッダーのプルダウンで選んだ言語 (localStorage.locale) と
      // 表示中ページの言語が違い、かつ対応ページ (data-alt-url) が存在する場合だけ
      // そちらへ移動する。描画前に実行して FOUC を避ける。
      (() => {
        const preferred = localStorage.getItem('locale');
        if (preferred !== 'ja' && preferred !== 'en') return;
        const { locale, altUrl } = document.documentElement.dataset;
        if (locale && altUrl && preferred !== locale) {
          location.replace(altUrl);
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <SiteHeader altUrl={altUrl} />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <AnalyticsEvents />
  </body>
</html>

<style is:global>
  main {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-16);
  }
</style>
