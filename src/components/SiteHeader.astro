---
import ThemeToggle from './ThemeToggle.astro';
import { getLocaleFromPath, localePath, LOCALES } from '../i18n';

interface Props {
  /** 反対言語での同一ページのパス。null なら未翻訳 (プルダウンはセクショントップへ) */
  altUrl?: string | null;
}

const { altUrl = null } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);

const nav = [
  { label: 'Notes', href: '/notes/' },
  { label: 'OSS', href: '/oss/' },
  { label: 'About', href: '/about/' },
  { label: 'Life', href: '/life/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;

function isActive(jaHref: string) {
  const href = localePath(locale, jaHref);
  if (href === '/' || href === '/en/') return currentPath === href;
  return currentPath === href || currentPath.startsWith(href);
}

const home = localePath(locale, '/');
---

<header class="site-header">
  <div class="inner">
    <a href={home} class="brand" aria-label="cilly, home">cilly</a>

    <nav aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={localePath(locale, item.href)}
                class:list={['nav-link', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="actions">
      <div class="lang-switch" role="radiogroup" aria-label="Language" data-alt-url={altUrl ?? undefined}>
        {
          LOCALES.map((l) => (
            <button
              type="button"
              role="radio"
              aria-checked={l === locale ? 'true' : 'false'}
              data-lang-value={l}
              aria-label={l === 'ja' ? '日本語' : 'English'}
            >
              {l.toUpperCase()}
            </button>
          ))
        }
      </div>
      <ThemeToggle />
    </div>
  </div>
</header>

<script>
  // 言語トグル: 選択を localStorage に保存し、反対言語の対応ページへ遷移する。
  // 対応ページが無い (data-alt-url 無し = 未翻訳記事など) 場合は Notes 一覧へフォールバック。
  const group = document.querySelector<HTMLElement>('.lang-switch');
  if (group) {
    group.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-lang-value]');
      if (!btn) return;
      const target = btn.dataset.langValue!;
      localStorage.setItem('locale', target);

      const current = document.documentElement.dataset.locale;
      if (target === current) return;

      const altUrl = group.dataset.altUrl;
      if (altUrl) {
        location.href = altUrl;
        return;
      }
      const inNotes = location.pathname.includes('/notes/');
      if (target === 'en') {
        location.href = inNotes ? '/en/notes/' : '/en/';
      } else {
        location.href = inNotes ? '/notes/' : '/';
      }
    });
  }
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .inner {
    max-width: var(--max-w-wide);
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
  }

  .brand {
    color: var(--fg);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }

  .brand:hover {
    color: var(--link-hover);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  .nav-link {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.875rem;
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--fg);
  }

  .nav-link.active {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* ThemeToggle と同じセグメント型ピルに揃える */
  .lang-switch {
    display: inline-flex;
    gap: 0;
    padding: 2px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg);
  }

  .lang-switch button {
    appearance: none;
    background: transparent;
    border: 0;
    padding: var(--space-1) var(--space-3);
    font-size: 0.75rem;
    color: var(--fg-subtle);
    cursor: pointer;
    border-radius: calc(var(--radius-md) - 2px);
    line-height: 1.4;
    letter-spacing: 0.02em;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .lang-switch button:hover {
    color: var(--fg);
  }

  .lang-switch button[aria-checked='true'] {
    background: var(--bg-elevated);
    color: var(--fg);
  }

  @media (max-width: 720px) {
    .inner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: var(--space-3);
    }

    nav {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    nav ul {
      justify-content: flex-start;
    }
  }
</style>
